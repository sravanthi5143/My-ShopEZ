# ==============================================================================
# Shopezz E-Commerce Project .gitignore
# ==============================================================================

# Node Modules (root, client, and server directories)
node_modules/
client/node_modules/
server/node_modules/

# Environment Configuration Files (sensitive credentials)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
server/.env
client/.env

# Production Build Artifacts and Compilation Output
dist/
build/
client/dist/
client/build/
server/dist/
server/build/
.dist/

# System / OS Specific Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE and Text Editor Workspace Settings
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath
.settings/

# Preserve recommended VSCode workspace directories but ignore user settings
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/snippets

# Log Files and Debug Reports
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Test Coverage Reports and Diagnostics Cache
coverage/
.nyc_output/
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.vite/
.npm/

# Temporary Files and Scratch Folders
tmp/
temp/
scratch/

# Local Media / User Uploaded Assets (for local uploads store)
server/public/uploads/*
!server/public/uploads/.gitkeep
client/public/uploads/*
!client/public/uploads/.gitkeep
